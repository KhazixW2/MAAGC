{
    "interface_version": 2,
    "name": "MaaGC",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaGC!",
    "github": "https://github.com/MaaXYZ/MAAGC",
    "version": "1.0.0",
    "mirrorchyan_rid": "MaaGC",
    "mirrorchyan_multiplatform": false,
    "controller": [
        {
            "name": "ADB",
            "type": "Adb",
            "label": "模拟器",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "agent": {
        "child_exec": "./python/python.exe",
        "child_args": [
            "-u",
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "GameStartUp",
            "doc": [
                "### 启动游戏",
                "",
                "启动游戏客户端，完成登录流程。",
                "",
                "**功能说明：**",
                "- 自动启动游戏",
                "- 处理登录界面",
                "- 进入主界面"
            ]
        },
        {
            "name": "市场折扣物品",
            "entry": "BigMapMarket",
            "doc": [
                "### 市场折扣物品",
                "",
                "进入大地图市场进行管理操作。",
                "",
                "**功能说明：**",
                "- 自动进入市场界面",
                "- 处理市场相关操作",
                "- 完成后返回大地图"
            ]
        },
        {
            "name": "商城免费礼包",
            "entry": "BigMapMall",
            "doc": [
                "### 商城免费礼包",
                "",
                "进入大地图商城进行购物操作。",
                "",
                "**功能说明：**",
                "- 自动进入商城界面",
                "- 处理商城相关操作",
                "- 完成后返回大地图",
                "",
                "**使用场景：**",
                "- 商城物品购买",
                "- 商城任务处理"
            ]
        },
        {
            "name": "悬赏令领取",
            "entry": "BigMapRewardToken",
            "doc": [
                "### 悬赏令领取",
                "",
                "进入大地图悬赏令界面进行管理操作。",
                "",
                "**功能说明：**",
                "- 自动进入悬赏令界面",
                "- 处理悬赏令领取，包含女王、王族令牌",
                "- 完成后返回大地图",
                "",
                "**使用场景：**",
                "- 悬赏令奖励领取"
            ]
        },
        {
            "name": "推月",
            "entry": "Auto_FightTask",
            "doc": [
                "### 推月（月度任务）",
                "",
                "自动执行月度战斗任务。",
                "",
                "**功能说明：**",
                "- 自动处理月度事件",
                "- 执行战斗任务",
                "- 处理节日活动"
            ]
        },
        {
            "name": "推年",
            "entry": "Auto_YearlyTask",
            "doc": [
                "### 推年（年度任务）",
                "",
                "自动执行年度任务流程。",
                "",
                "**功能说明：**",
                "- 按月份处理全年事件",
                "- 自动推进游戏时间",
                "- 处理年度特殊事件"
            ]
        },
        {
            "name": "自动孩子取名字——小工具",
            "entry": "Auto_PannelCheck",
            "doc": [
                "### 自动孩子取名字",
                "",
                "识别子项信息并自动生成名字的小工具。",
                "",
                "**功能说明：**",
                "- 识别父母信息（姓名、爵位、佣兵团）",
                "- 识别潜力面板（六维属性：力量、体质、技巧、感知、敏捷、意志）",
                "- 识别血脉面板（血统名称及百分比）",
                "- 识别特性面板（特性列表）",
                "- 自动生成子孙名字",
                "",
                "**命名规则：**",
                "- 格式：`最高属性 + 次高属性 + 特性 + 爵位`",
                "- 示例：`力 ss 技 ss 太科公`",
                "",
                "**属性等级：**",
                "- SS: > 0.93",
                "- S: 0.74-0.93",
                "- A: 0.55-0.74",
                "- B: 0.35-0.55",
                "- C: 0.20-0.35",
                "- D: 0.10-0.20",
                "- E: < 0.10",
                "",
                "**使用场景：**",
                "- 佣兵生娃事件后自动触发",
                "- 手动执行进行孩子命名"
            ]
        }
    ]
}